APP_NAME=backend-temp
ENVIRONMENT=dev
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/backend_temp
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
SSE_HEARTBEAT_SECONDS=15
SSE_BACKLOG_SIZE=200
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_MAX_RETRIES=3
CELERY_RETRY_BACKOFF_SECONDS=5
CELERY_RETRY_BACKOFF_MAX_SECONDS=60
MODEL_ALLOWLIST=builtin,gpt-4.1-mini,gpt-4.1
TENANT_MODEL_POLICIES_JSON={"public":["builtin","gpt-4.1-mini"],"vip":["builtin","gpt-4.1-mini","gpt-4.1"]}
TOOL_CALL_TIMEOUT_SECONDS_DEFAULT=15
TOOL_CALL_TIMEOUT_SECONDS_MAX=60
TENANT_TOOL_POLICIES_JSON={"public":["time_now","session_lookup","summarize_chunk"],"vip":["*"]}
AGENT_TOOL_BINDINGS_JSON={"report":{"skills":["echo"],"tools":["session_lookup","summarize_chunk"]},"research":{"skills":["echo","uppercase"],"tools":["session_lookup","http_search_wrapper"]}}
CONTEXT_BUDGET_TOKENS=4000
CONTEXT_RATIO_SYSTEM_TENANT=0.10
CONTEXT_RATIO_MEMORY_KV=0.15
CONTEXT_RATIO_SUMMARY=0.25
CONTEXT_RATIO_RECENT_MESSAGES=0.50
CONTEXT_RECENT_MESSAGE_LIMIT=24
SUMMARY_TRIGGER_TURNS=8
SUMMARY_TRIGGER_TOKEN_THRESHOLD=2000
MAX_MESSAGES_PER_SESSION=2000
MAX_SUMMARY_VERSIONS=5
MAX_KV_PER_SESSION=200
KV_TTL_HOURS=72
